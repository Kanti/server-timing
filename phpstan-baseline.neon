parameters:
	ignoreErrors:
		-
			message: '#^Trait Kanti\\ServerTiming\\DataProcessor\\XClassContentDataProcessorTrait is used zero times and is not analysed\.$#'
			identifier: trait.unused
			count: 1
			path: Classes/DataProcessor/XClassContentDataProcessorTrait.php

		-
			message: '#^Property Kanti\\ServerTiming\\Dto\\StopWatch\:\:\$span has unknown class Sentry\\Tracing\\Span as its type\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Dto/StopWatch.php

		-
			message: '#^Using nullsafe method call on non\-nullable type Kanti\\ServerTiming\\Dto\\StopWatch\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: Classes/Middleware/WrapMiddleware.php

		-
			message: '#^Call to method finish\(\) on an unknown class Sentry\\Tracing\\Span\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Call to method finish\(\) on an unknown class Sentry\\Tracing\\Transaction\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

