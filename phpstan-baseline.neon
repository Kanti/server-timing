			message: '#^Call to static method createFromHttpStatusCode\(\) on an unknown class Sentry\\Tracing\\SpanStatus\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Call to static method getCurrentHub\(\) on an unknown class Sentry\\SentrySdk\.$#'
			identifier: class.notFound
			count: 3
			path: Classes/Service/SentryService.php

		-
			message: '#^Call to static method ok\(\) on an unknown class Sentry\\Tracing\\SpanStatus\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Call to static method unknownError\(\) on an unknown class Sentry\\Tracing\\SpanStatus\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Class Sentry\\Tracing\\Span not found\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Function Sentry\\continueTrace not found\.$#'
			identifier: function.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Function Sentry\\getBaggage not found\.$#'
			identifier: function.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Function Sentry\\getTraceparent not found\.$#'
