			path: Classes/Service/SentryService.php

		-
			message: '#^Call to method setStartTimestamp\(\) on an unknown class Sentry\\Tracing\\Span\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

