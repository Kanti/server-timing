			identifier: class.notFound
			count: 2
			path: Classes/Service/SentryService.php

		-
			message: '#^Method Kanti\\ServerTiming\\Service\\SentryService\:\:addResultToTransaction\(\) has invalid return type Sentry\\Tracing\\Transaction\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Method Kanti\\ServerTiming\\Service\\SentryService\:\:createTransactionContextFromCli\(\) has invalid return type Sentry\\Tracing\\TransactionContext\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Method Kanti\\ServerTiming\\Service\\SentryService\:\:createTransactionContextFromRequest\(\) has invalid return type Sentry\\Tracing\\TransactionContext\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Method Kanti\\ServerTiming\\Service\\SentryService\:\:getSentryClient\(\) has invalid return type Sentry\\ClientInterface\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Method Kanti\\ServerTiming\\Service\\SentryService\:\:startTransaction\(\) has invalid return type Sentry\\Tracing\\Transaction\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Method Kanti\\ServerTiming\\Service\\SentryService\:\:startTransaction\(\) should return Sentry\\Tracing\\Transaction but returns Sentry\\Tracing\\Transaction\|null\.$#'
			identifier: return.type
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^PHPDoc tag @var for variable \$stack contains unknown class Sentry\\Tracing\\Span\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Parameter \$span of method Kanti\\ServerTiming\\Service\\SentryService\:\:updateSpan\(\) has invalid type Sentry\\Tracing\\Span\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Parameter \$transaction of method Kanti\\ServerTiming\\Service\\SentryService\:\:addResultToTransaction\(\) has invalid type Sentry\\Tracing\\Transaction\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Property Kanti\\ServerTiming\\Service\\SentryService\:\:\$transaction has unknown class Sentry\\Tracing\\Transaction as its type\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Used function Sentry\\continueTrace not found\.$#'
			identifier: function.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Used function Sentry\\getBaggage not found\.$#'
			identifier: function.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Used function Sentry\\getTraceparent not found\.$#'
			identifier: function.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Method Doctrine\\DBAL\\Driver\\Middleware\\AbstractStatementMiddleware\:\:execute\(\) invoked with 1 parameter, 0 required\.$#'
			identifier: arguments.count
			count: 1
			path: Classes/SqlLogging/LoggingStatement.php

		-
			message: '#^Method Kanti\\ServerTiming\\SqlLogging\\LoggingStatement\:\:execute\(\) has parameter \$params with no type specified\.$#'
			identifier: missingType.parameter
			count: 1
			path: Classes/SqlLogging/LoggingStatement.php

		-
			message: '#^Method Kanti\\ServerTiming\\Utility\\TimingUtility\:\:chunkStringArray\(\) should return list\<string\> but returns array\<int\<0, max\>, string\>\.$#'
			identifier: return.type
			count: 1
			path: Classes/Utility/TimingUtility.php

		-
			message: '#^Call to static method PHPUnit\\Framework\\Assert\:\:assertIsFloat\(\) with float will always evaluate to true\.$#'
			identifier: staticMethod.alreadyNarrowedType
			count: 3
			path: Tests/TimingUtilityTest.php

		-
			message: '#^Call to static method PHPUnit\\Framework\\Assert\:\:assertIsFloat\(\) with null will always evaluate to false\.$#'
			identifier: staticMethod.impossibleType
			count: 1
			path: Tests/TimingUtilityTest.php

		-
			message: '#^Call to static method PHPUnit\\Framework\\Assert\:\:assertIsList\(\) with list\<string\> will always evaluate to true\.$#'
			identifier: staticMethod.alreadyNarrowedType
			count: 1
			path: Tests/TimingUtilityTest.php

		-
			message: '#^Parameter \#1 \$expected of static method PHPUnit\\Framework\\Assert\:\:assertSame\(\) contains unresolvable type\.$#'
			identifier: argument.unresolvableType
			count: 1
			path: Tests/TimingUtilityTest.php
