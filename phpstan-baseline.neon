			message: '#^Call to method setStartTimestamp\(\) on an unknown class Sentry\\Tracing\\Transaction\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

		-
			message: '#^Call to method setStatus\(\) on an unknown class Sentry\\Tracing\\Transaction\.$#'
			identifier: class.notFound
			count: 2
			path: Classes/Service/SentryService.php

		-
			message: '#^Call to method startChild\(\) on an unknown class Sentry\\Tracing\\Span\.$#'
			identifier: class.notFound
			count: 1
			path: Classes/Service/SentryService.php

